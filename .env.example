# Environment Variables Template for AI GD Helper Buddy
# Copy this file to .env and fill in your actual API keys

# Gemini API Key (required for AI functionality)
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI API Key (optional, for future OpenAI integration)
VITE_OPENAI_API_KEY=your-openai-api-key-here

# Firebase Configuration (update with your project details)
VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Environment
NODE_ENV=development